<odoo>
    <!-- ==================== DESCUENTOS ==================== -->
    <record id="view_descuentos_list" model="ir.ui.view">
        <field name="name">etiquetas.descuentos.list</field>
        <field name="model">etiquetas.descuentos</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cantidad_descuento"/>
                <field name="zapato_id"/>
            </list>
        </field>
    </record>

    <record id="view_descuentos_form" model="ir.ui.view">
        <field name="name">etiquetas.descuentos.form</field>
        <field name="model">etiquetas.descuentos</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cantidad_descuento"/>
                        <field name="zapato_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_descuentos" model="ir.actions.act_window">
        <field name="name">Descuentos</field>
        <field name="res_model">etiquetas.descuentos</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ==================== ETIQUETAS ==================== -->
    <record id="view_etiquetas_list" model="ir.ui.view">
        <field name="name">etiquetas.etiquetas.list</field>
        <field name="model">etiquetas.etiquetas</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="color"/>
                <field name="zapato_ids"/>
            </list>
        </field>
    </record>

    <record id="view_etiquetas_form" model="ir.ui.view">
        <field name="name">etiquetas.etiquetas.form</field>
        <field name="model">etiquetas.etiquetas</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color"/>
                        <field name="zapato_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_etiquetas" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">etiquetas.etiquetas</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ==================== MENUS ==================== -->
   <menuitem id="menu_descuentos"
          name="Descuentos"
          parent="zapatos.menu_zapatos_root"
          action="action_descuentos"
          sequence="20"/>

    <menuitem id="menu_etiquetas"
          name="Etiquetas"
          parent="zapatos.menu_zapatos_root"
          action="action_etiquetas"
          sequence="30"/>
</odoo>