<odoo>
<!-- Las etiquetas-->
    <record id="view_etiquetas_list" model="ir.ui.view">
        <field name="name">etiquetas.etiquetas.list</field>
        <field name="model">etiquetas.etiquetas</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="color" widget="color"/>
                <field name="zapato_ids"/>
            </list>
        </field>
    </record>

    <record id="view_etiquetas_form" model="ir.ui.view">
        <field name="name">etiquetas.etiquetas.form</field>
        <field name="model">etiquetas.etiquetas</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="zapato_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_etiquetas" model="ir.actions.act_window">
        <field name="name">Etiquetas</field>
        <field name="res_model">etiquetas.etiquetas</field>
        <field name="view_mode">list,form</field>
    </record>

<!-- La herencia de vista de zapato-->
    <record id="view_zapato_form_etiquetas" model="ir.ui.view">
        <field name="name">zapatos.zapato.form.etiquetas</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <field name="descuento"/>
                <field name="precio_final" readonly="1"/>
                <field name="etiqueta_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <!--Los menus -->

    <menuitem id="menu_etiquetas"
          name="Etiquetas"
          parent="zapatos.menu_zapatos_root"
          action="action_etiquetas"
          sequence="30"/>
</odoo>