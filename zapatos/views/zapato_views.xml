<odoo>
    <record id="view_zapato_list" model="ir.ui.view">
        <field name="name">zapatos.zapato.list</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="talla"/>
                <field name="precio"/>
                <field name="stock"/>
                <field name="activo"/>
                <field name="stock_bajo" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_zapato_form" model="ir.ui.view">
        <field name="name">zapatos.zapato.form</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="alert alert-warning" role="alert"
                        invisible="not stock_bajo">
                            <strong>Stock Bajo:</strong>
                                Este producto tiene menos de 5 unidades. Reponga el inventario.
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="talla"/>
                        <field name="precio"/>
                        <field name="stock"/>
                        <field name="activo"/>
                        <field name="stock_bajo" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_zapato" model="ir.actions.act_window">
        <field name="name">Zapatos</field>
        <field name="res_model">zapatos.zapato</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_zapatos_root" name="Zapatos" sequence="10"/>

    <menuitem id="menu_zapatos_zapatos"
              name="Registrar Zapatos"
              parent="menu_zapatos_root"
              action="action_zapato"
              sequence="10"/>
</odoo>