<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_zapato_form_inherit_proveedor_categoria"
            model="ir.ui.view">

        <field name="name">
            zapatos.form.inherit.proveedor.categoria
        </field>

        <field name="model">zapatos.zapato</field>

        <field name="inherit_id"
               ref="zapatos.view_zapato_form"/>

        <field name="arch" type="xml">

            <xpath expr="//group" position="inside">

                <field name="proveedor_id"/>

                <field name="categoria_id"/>

            </xpath>

        </field>

    </record>

</odoo>