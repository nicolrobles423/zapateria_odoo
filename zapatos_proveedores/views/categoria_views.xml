<?xml version="1.0" encoding="utf-8"?>
<odoo>

   
    <record id="view_categoria_list" model="ir.ui.view">
        <field name="name">zapatos.categoria.list</field>
        <field name="model">zapatos.categoria</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="descripcion"/>
            </list>
        </field>
    </record>

   
    <record id="view_categoria_form" model="ir.ui.view">
        <field name="name">zapatos.categoria.form</field>
        <field name="model">zapatos.categoria</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    
    <record id="action_categorias" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">zapatos.categoria</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>