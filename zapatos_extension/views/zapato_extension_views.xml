<odoo>
 
    <record id="view_zapato_form_extension" model="ir.ui.view">
        <field name="name">zapatos.zapato.form.extension</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_disponible" string="Pasar a Disponible"
                            type="object" class="oe_highlight"
                            invisible="state not in ('draft', 'out_stock')"/>
                    <button name="action_agotado" string="Marcar como Agotado"
                            type="object"
                            invisible="state != 'available'"/>
                    <button name="action_descontinuar" string="Descontinuar producto"
                            type="object"
                            invisible="state == 'discontinued'"/>
                    <button name="action_borrador" string="Regresar a Borrador"
                            type="object"
                            invisible="state != 'discontinued'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,available,out_stock"/>
                </header>
            </xpath>
            <xpath expr="//group" position="inside">
                <field name="codigo"/>
                <field name="marca"/>
                <field name="color"/>
                <field name="material"/>
                <field name="stock_minimo"/>
                <field name="valor_inventario" readonly="1"/>
                <field name="descripcion"/>
            </xpath>
        </field>
    </record>
 
    <record id="view_zapato_list_extension" model="ir.ui.view">
        <field name="name">zapatos.zapato.list.extension</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_list"/>


        <!-- CORREGIDO: se ordenó type="xml" sin espacios innecesarios -->

        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-danger">stock_bajo == True or stock == 0</attribute>
                <attribute name="decoration-warning">stock &gt; 0 and stock &gt;= 5 and stock &lt;= stock_minimo</attribute>
                <attribute name="decoration-success">stock &gt; stock_minimo</attribute>
            </xpath>
            
            <xpath expr="//list" position="inside">
                <field name="codigo"/>
                <field name="marca"/>
                <field name="color"/>
                <field name="state"/>
                <field name="valor_inventario"/>
                <field name="stock_minimo" column_invisible="1"/>
            </xpath>
        </field>
    </record>
 
</odoo>
 
